# ──────────────────────────────────────────────────────────────────────────────
# EV YEMEKLERİ — Ortam Değişkenleri Şablonu
# .env.local olarak kopyalayın ve doldurun.
# Production değerleri → Vercel Dashboard'dan girilir.
# ──────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://PROJE_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
DATABASE_URL=postgresql://postgres.PROJE_ID:SIFRE@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# ── İyzico ────────────────────────────────────────────────────────────────────
IYZICO_API_KEY=sandbox-...
IYZICO_SECRET_KEY=sandbox-...
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com
IYZICO_CALLBACK_URL=http://localhost:3000/api/payments/callback

# ── Netgsm SMS ────────────────────────────────────────────────────────────────
NETGSM_USERCODE=9XXXXXXXXX
NETGSM_PASSWORD=NETGSM_SIFRE
NETGSM_MSGHEADER=EVYEMEKLERI

# ── Firebase FCM ──────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=ev-yemekleri
FIREBASE_ACCESS_TOKEN=           # Google OAuth2 token (opsiyonel — FCM REST için)
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@ev-yemekleri.iam.gserviceaccount.com
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSy...
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_VAPID_KEY=BLxxxxxxx...

# ── Upstash Redis ─────────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://xxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxxxxxxx...

# ── Google Maps ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_KEY=AIzaSy...

# ── Uygulama ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
AUTH_SECRET=buraya-guclu-rastgele-bir-string-gelin

# ── Resend E-posta ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=bildirim@ev-yemekleri.com
